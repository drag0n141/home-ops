{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Auto-merge Containers",
      matchDatasources: ["docker"],
      automerge: true,
      automergeType: "pr",
      ignoreTests: false,
      excludePackageNames: ["/dragonflydb/", "/zibbp/", "/immich-app/", "/siderolabs/", "/koenkk/"],
      matchUpdateTypes: ["digest"],
    },
    {
      description: "Auto-merge OCI Charts",
      matchDatasources: ["docker"],
      automerge: true,
      automergeType: "pr",
      ignoreTests: false,
      matchPackageNames: ["/helm-charts/renovate-operator", "/kube-prometheus-stack/", "/netbox-chart/"],
      matchUpdateTypes: ["minor", "patch"],
    },
    {
      description: "Auto-merge high-cadence packages weekly",
      matchDatasources: ["docker"],
      automerge: true,
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["ghcr.io/renovatebot/renovate"],
      schedule: ["before 6am on Monday"],
    },
  ]
}
